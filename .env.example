# Kopiere diese Datei zu ".env.local" und trage deine Supabase-Werte ein.
# Beide Werte sind öffentlich unbedenklich (der Schutz kommt aus den RLS-Policies).
# Zu finden im Supabase-Dashboard unter: Project Settings -> API

VITE_SUPABASE_URL=https://DEIN-PROJEKT.supabase.co
VITE_SUPABASE_ANON_KEY=DEIN-ANON-PUBLIC-KEY
